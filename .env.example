# LocalLift Studio - ejemplo de entorno

# Servidor principal
PORT=5173
HOST=127.0.0.1
NODE_ENV=development

# En produccion, cambia HOST a 0.0.0.0 si tu proveedor lo necesita.
# HOST=0.0.0.0

# Seguridad admin
# Obligatorio en produccion para proteger /api/businesses/*
LOCALLIFT_ADMIN_TOKEN=change-me-use-a-long-random-token

# CORS
# Vacio permite "*" para desarrollo local.
# En produccion usa el dominio real del frontend. Se permite lista separada por comas.
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173

# Base JSON local
BUSINESS_DB_FILE=data/business-db.json
BUSINESS_DB_BACKUPS=true

# Chatbot IA opcional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Tienda / Stripe / email
STORE_ADMIN_TOKEN=change-me-use-a-long-random-token
CHECKOUT_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ORDER_EMAIL_TO=
RESEND_API_KEY=

# Google opcional
GOOGLE_MAPS_API_KEY=
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_BUSINESS_PROFILE_ACCESS_TOKEN=
GOOGLE_WORKSPACE_ADMIN_ACCESS_TOKEN=
