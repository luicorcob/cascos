# LocalLift Studio - ejemplo de entorno

# Servidor principal
PORT=5173
HOST=127.0.0.1
NODE_ENV=development

# En produccion, cambia HOST a 0.0.0.0 si tu proveedor lo necesita.
# HOST=0.0.0.0

# Seguridad admin
# Obligatorio en produccion para proteger /api/businesses/*
LOCALLIFT_ADMIN_TOKEN=
# Sesiones del portal cliente. Usa un secreto largo y estable en produccion.
CLIENT_SESSION_SECRET=
CLIENT_SESSION_TTL_SECONDS=1209600

# CORS
# Vacio permite "*" para desarrollo local.
# En produccion usa el dominio real del frontend. Se permite lista separada por comas.
CORS_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5500,http://localhost:5500

# Persistencia del dashboard
# Desarrollo rapido: deja BUSINESS_STORE=json y usa data/business-db.json.
# Produccion recomendada: BUSINESS_STORE=postgres + DATABASE_URL.
BUSINESS_STORE=json
DATABASE_URL=
# SSL se activa automaticamente para hosts remotos. Usa PGSSLMODE=disable solo en Postgres local.
PGSSLMODE=
# Si PostgreSQL esta vacio, permite importar data/business-db.json en desarrollo.
BUSINESS_DB_BOOTSTRAP_FROM_JSON=true

# Base JSON local / fallback
BUSINESS_DB_FILE=data/business-db.json
BUSINESS_DB_BACKUP_DIR=data/backups
BUSINESS_DB_BACKUPS=true

# Publicacion temporal de demos desde el Studio
DEMO_PUBLISH_DIR=data/demo-publishes
DEMO_PUBLISH_TTL_HOURS=168
DEMO_PUBLISH_MAX_BODY_BYTES=14680064
# Opcional: fuerza el dominio publico usado en los enlaces /demos/...
# Necesario si el backend esta detras de un proxy que no manda Host publico.
# Ejemplo: DEMO_PUBLIC_BASE_URL=https://tu-api.onrender.com
DEMO_PUBLIC_BASE_URL=
# Opcional: sube la demo a un publicador remoto, por ejemplo Cloudflare Workers + KV.
# Asi el enlace publico funciona aunque el Studio este en local.
# Ejemplo: DEMO_REMOTE_PUBLISH_URL=https://dls-demo-publisher.tu-cuenta.workers.dev
DEMO_REMOTE_PUBLISH_URL=
DEMO_REMOTE_PUBLISH_TOKEN=

# Proteccion basica de endpoints publicos (por IP y ventana)
PUBLIC_LEAD_RATE_LIMIT=6
PUBLIC_LEAD_RATE_LIMIT_WINDOW_MS=600000
PUBLIC_BOOKING_RATE_LIMIT=6
PUBLIC_BOOKING_RATE_LIMIT_WINDOW_MS=600000
PUBLIC_EVENT_RATE_LIMIT=120
PUBLIC_EVENT_RATE_LIMIT_WINDOW_MS=600000
PUBLIC_DISCOVERY_RATE_LIMIT=40
PUBLIC_DISCOVERY_RATE_LIMIT_WINDOW_MS=600000
CLIENT_LOGIN_RATE_LIMIT=10
CLIENT_LOGIN_RATE_LIMIT_WINDOW_MS=600000
SITE_IMAGE_RATE_LIMIT=20
SITE_IMAGE_RATE_LIMIT_WINDOW_MS=600000
STOCK_IMAGE_RATE_LIMIT=60
STOCK_IMAGE_RATE_LIMIT_WINDOW_MS=600000
STOCK_IMAGE_DOWNLOAD_RATE_LIMIT=120
STOCK_IMAGE_DOWNLOAD_RATE_LIMIT_WINDOW_MS=600000
DEMO_PUBLISH_RATE_LIMIT=12
DEMO_PUBLISH_RATE_LIMIT_WINDOW_MS=3600000
GOOGLE_API_RATE_LIMIT=60
GOOGLE_API_RATE_LIMIT_WINDOW_MS=600000
RADAR_WRITE_RATE_LIMIT=30
RADAR_WRITE_RATE_LIMIT_WINDOW_MS=600000
API_MAX_BODY_BYTES=16777216
API_MAX_URL_BYTES=8192
# HSTS se envia solo en NODE_ENV=production.
SECURITY_HSTS_MAX_AGE_SECONDS=15552000

# Logging y alertas de autenticacion
LOG_LEVEL=info
ACCESS_LOGS=true
LOG_STACKS=true
AUTH_FAILURE_ALERT_THRESHOLD=5
AUTH_FAILURE_ALERT_WINDOW_MS=600000

# Chatbot IA opcional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Modulo de imagenes para webs
# UNSPLASH_ACCESS_KEY alimenta tanto /api/site-images como /api/stock-images.
# Usa solo Access Key en el servidor; no pongas Secret Key en el frontend.
# /api/site-images usa Unsplash primero, Pexels como alternativa y Pixabay como fallback.
# /api/stock-images usa Unsplash primero y Wikimedia Commons como fallback sin clave.
# Si no hay claves, /api/site-images devuelve null por seccion y avisos.
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Tienda / Stripe / email
STORE_ADMIN_TOKEN=
CHECKOUT_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
ORDER_EMAIL_TO=
RESEND_API_KEY=

# Google opcional
GOOGLE_MAPS_API_KEY=
# DLS Radar: "openstreetmap" usa Nominatim + Overpass con datos reales sin
# clave. "places" usa Places API (New) + Geocoding desde el servidor.
# "demo" queda reservado a ejemplos explícitos y nunca genera enlaces de mapa.
DLS_DISCOVERY_PROVIDER=openstreetmap
GOOGLE_PLACES_API_KEY=
RADAR_LEADS_DB_FILE=data/radar-leads.json
DLS_DISCOVERY_CACHE_TTL_MS=900000
DLS_RADAR_USER_AGENT=DLS-Radar/1.0 (Digital Local Sites; https://digitallocalsites.com)
# Endpoints sustituibles para infraestructura propia o un proveedor contratado.
DLS_NOMINATIM_URL=https://nominatim.openstreetmap.org
DLS_OVERPASS_URL=https://overpass-api.de/api/interpreter
# OAuth web-server multi-negocio. El redirect debe coincidir exactamente con
# el configurado en Google Cloud, por ejemplo:
# http://127.0.0.1:5173/api/google/oauth/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
# Secreto aleatorio de 32+ caracteres. No cambiarlo mientras existan tokens.
GOOGLE_TOKEN_ENCRYPTION_KEY=
GOOGLE_AUTH_DB_FILE=data/google-auth-db.json
# Fuerza consentimiento para obtener refresh_token al conectar/reconectar.
GOOGLE_OAUTH_PROMPT=consent

# Compatibilidad temporal con el antiguo backend de ejemplo. Para nuevos
# clientes usa OAuth multi-negocio y deja estos tokens vacios.
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_BUSINESS_PROFILE_ACCESS_TOKEN=
GOOGLE_WORKSPACE_ADMIN_ACCESS_TOKEN=
