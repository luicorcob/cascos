name = "dls-demo-publisher"
main = "demo-publisher-worker.js"
compatibility_date = "2026-07-01"
workers_dev = true

[[kv_namespaces]]
binding = "DEMOS"
id = "REPLACE_WITH_KV_NAMESPACE_ID"

[vars]
DEMO_TTL_HOURS = "24"
DEMO_MAX_HTML_BYTES = "14680064"
CORS_ORIGIN = "*"

# Set the publish token as a secret, not as a plain var:
# npx wrangler secret put DEMO_PUBLISH_TOKEN --config cloudflare/wrangler.demo-publisher.toml
